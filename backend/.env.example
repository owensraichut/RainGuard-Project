# Backend environment variables

# Enable real TMD data ingestion
USE_REAL_TMD_DATA=1

# Base URL for TMD API (replace with actual endpoint)
TMD_API_BASE_URL=https://api.tmd.go.th

# TMD API token / key
TMD_API_TOKEN=your_tmd_api_token_here

# LINE Notify token for alert messages (optional)
# LINE Notify support has been removed in favor of in-app web alerts.
